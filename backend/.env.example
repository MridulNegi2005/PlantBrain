# Postgres (hosted on cloud VM) — must have pgvector extension enabled
# Note the +psycopg driver (psycopg3, not psycopg2)
DATABASE_URL=postgresql+psycopg://user:password@host:5432/plantbrain

# LLM
ANTHROPIC_API_KEY=

# Embeddings (local, no key needed if using bge/nomic via sentence-transformers)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# App
ENV=development
JWT_SECRET=change-me-in-production
CORS_ORIGINS=http://localhost:3000

# Uploads
MAX_UPLOAD_MB=20
