# Postgres (hosted on cloud VM) — must have the pgvector extension available.
# The app assembles these into a connection URL (special chars encoded automatically).
POSTGRES_DB=plantbrain
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# LLM is OPTIONAL and only used from Interval 3+ (entity extraction, RCA, cited
# answers). Leave blank to run a free local model (Ollama) — no paid key required.
ANTHROPIC_API_KEY=

# Embeddings run locally via sentence-transformers — free, no key.
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

ENV=development
JWT_SECRET=change-me-in-production
CORS_ORIGINS=http://localhost:3000
MAX_UPLOAD_MB=20
