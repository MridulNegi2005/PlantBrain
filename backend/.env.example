# Postgres (hosted on cloud VM) — must have the pgvector extension available.
# The app assembles these into a connection URL (special chars encoded automatically).
# For a zero-config local demo instead, set: DATABASE_URL=sqlite:///./plantbrain.db
DATABASE_URL=
POSTGRES_DB=plantbrain
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# LLM (Interval 3+): OpenAI-compatible. Default = Groq free tier.
# Get a free key at https://console.groq.com/keys and paste it below.
# To use local Ollama instead: LLM_BASE_URL=http://localhost:11434/v1, LLM_MODEL=qwen2.5:7b, LLM_API_KEY=ollama
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# Embeddings run locally via sentence-transformers — free, no key.
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

ENV=development
JWT_SECRET=change-me-in-production
CORS_ORIGINS=http://localhost:3000
MAX_UPLOAD_MB=20
